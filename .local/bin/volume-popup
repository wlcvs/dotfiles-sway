#!/usr/bin/env python3
import gi, os, sys, signal, threading
gi.require_version('Gtk', '3.0')
gi.require_version('GtkLayerShell', '0.1')
from gi.repository import Gtk, Gdk, GLib, GtkLayerShell
import subprocess, json

PIDFILE = '/tmp/volume-popup.pid'

def toggle_or_exit():
    if os.path.exists(PIDFILE):
        try:
            pid = int(open(PIDFILE).read())
            os.kill(pid, signal.SIGTERM)
            os.unlink(PIDFILE)
            sys.exit(0)
        except (ProcessLookupError, ValueError, OSError):
            pass
    with open(PIDFILE, 'w') as f:
        f.write(str(os.getpid()))

toggle_or_exit()

for _pf in ['/tmp/wifi-popup.pid']:
    try:
        os.kill(int(open(_pf).read()), signal.SIGTERM)
        os.unlink(_pf)
    except Exception:
        pass

CSS = b"""
window {
    background-color: #0a0a0a;
    border: 1px solid #27272a;
}
#wrap {
    padding: 6px 5px 6px 5px;
}
scale {
    outline: none;
    min-width: 16px;
}
scale trough {
    background-color: #1c1c1e;
    min-width: 4px;
    border-radius: 0;
    margin: 0 6px;
}
scale highlight {
    background-color: #52525b;
    border-radius: 0;
}
scale slider {
    background-color: #e4e4e7;
    border-radius: 0;
    min-width: 16px;
    min-height: 4px;
    border: none;
    box-shadow: none;
    margin: 0;
}
scale slider:hover {
    background-color: #ffffff;
}
#label {
    color: #71717a;
    font-family: "JetBrains Mono";
    font-size: 10px;
    margin-top: 4px;
}
#label.muted {
    color: #3f3f46;
}
"""

def get_vol():
    try:
        out = subprocess.check_output(
            ['wpctl', 'get-volume', '@DEFAULT_AUDIO_SINK@'], text=True)
        return round(float(out.split()[1]) * 100), 'MUTED' in out
    except Exception:
        return 50, False

def set_vol(v):
    subprocess.run(['wpctl', 'set-volume', '-l', '1.0',
                    '@DEFAULT_AUDIO_SINK@', f'{max(0,min(100,int(v)))}%'])

def toggle_mute():
    subprocess.run(['wpctl', 'set-mute', '@DEFAULT_AUDIO_SINK@', 'toggle'])

class VolumePopup(Gtk.Window):
    def __init__(self):
        super().__init__()

        GLib.unix_signal_add(GLib.PRIORITY_DEFAULT, signal.SIGTERM, self._quit)

        GtkLayerShell.init_for_window(self)
        GtkLayerShell.set_layer(self, GtkLayerShell.Layer.TOP)
        GtkLayerShell.set_keyboard_mode(self, GtkLayerShell.KeyboardMode.ON_DEMAND)
        GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.TOP, True)
        GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.RIGHT, True)
        GtkLayerShell.set_margin(self, GtkLayerShell.Edge.TOP, 4)
        GtkLayerShell.set_margin(self, GtkLayerShell.Edge.RIGHT, 100)

        css = Gtk.CssProvider()
        css.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), css,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        self.vol, self.muted = get_vol()
        self._block = False

        wrap = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        wrap.set_name('wrap')

        self.scale = Gtk.Scale.new_with_range(Gtk.Orientation.VERTICAL, 0, 100, 1)
        self.scale.set_inverted(True)
        self.scale.set_draw_value(False)
        self.scale.set_size_request(28, 100)
        self.scale.set_value(self.vol)
        self.scale.connect('value-changed', self._on_scale)

        self.lbl = Gtk.Label()
        self.lbl.set_name('label')
        self._refresh_label()

        wrap.pack_start(self.scale, True, True, 0)
        wrap.pack_start(self.lbl, False, False, 0)
        self.add(wrap)

        self.connect('key-press-event', self._on_key)
        self.connect('destroy', self._cleanup)
        self._start_sway_watch()

    def _start_sway_watch(self):
        self._sway = subprocess.Popen(
            ['swaymsg', '-t', 'subscribe', '["workspace","window"]'],
            stdout=subprocess.PIPE, bufsize=1)
        t = threading.Thread(target=self._sway_thread, daemon=True)
        t.start()

    def _sway_thread(self):
        for raw in self._sway.stdout:
            try:
                ev = json.loads(raw)
                change = ev.get('change', '')
                if ('current' in ev and change == 'focus') or \
                   ('container' in ev and change == 'new'):
                    GLib.idle_add(self._quit)
                    return
            except Exception:
                pass

    def _cleanup(self, *_):
        if hasattr(self, '_sway'):
            self._sway.terminate()
        try:
            os.unlink(PIDFILE)
        except OSError:
            pass
        return False

    def _quit(self, *_):
        self._cleanup()
        Gtk.main_quit()
        return False

    def _refresh_label(self):
        ctx = self.lbl.get_style_context()
        if self.muted:
            self.lbl.set_text('MUTE')
            ctx.add_class('muted')
        else:
            self.lbl.set_text(f'{self.vol}%')
            ctx.remove_class('muted')

    def _on_scale(self, scale):
        if self._block:
            return
        self.vol = int(scale.get_value())
        self.muted = False
        set_vol(self.vol)
        self._refresh_label()

    def _set_vol(self, v):
        self.vol = max(0, min(100, v))
        self.muted = False
        self._block = True
        self.scale.set_value(self.vol)
        self._block = False
        set_vol(self.vol)
        self._refresh_label()

    def _on_key(self, _w, event):
        k = event.keyval
        if k in (Gdk.KEY_Escape, ord('q')):
            self._quit()
        elif k in (Gdk.KEY_Up, ord('k')):
            self._set_vol(self.vol + 5)
        elif k in (Gdk.KEY_Down, ord('j')):
            self._set_vol(self.vol - 5)
        elif k == ord('m'):
            toggle_mute()
            self.vol, self.muted = get_vol()
            self._block = True
            self.scale.set_value(self.vol)
            self._block = False
            self._refresh_label()
        return True

win = VolumePopup()
win.show_all()
Gtk.main()
