#!/usr/bin/env python3
import curses, subprocess

def get_vol():
    try:
        out = subprocess.check_output(['wpctl', 'get-volume', '@DEFAULT_AUDIO_SINK@'], text=True)
        muted = 'MUTED' in out
        vol = round(float(out.split()[1]) * 100)
        return min(100, max(0, vol)), muted
    except Exception:
        return 50, False

def set_vol(vol):
    subprocess.run(['wpctl', 'set-volume', '-l', '1.0', '@DEFAULT_AUDIO_SINK@', f'{vol}%'])

def toggle_mute():
    subprocess.run(['wpctl', 'set-mute', '@DEFAULT_AUDIO_SINK@', 'toggle'])

def main(stdscr):
    curses.curs_set(0)
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_WHITE, -1)
    curses.init_pair(2, 0, curses.COLOR_WHITE)

    vol, muted = get_vol()

    while True:
        stdscr.erase()
        h, w = stdscr.getmaxyx()
        bar_h = h - 4

        label = 'MUTE' if muted else f'{vol}%'
        stdscr.addstr(0, max(0, (w - len(label)) // 2), label, curses.A_BOLD)

        filled = round(vol / 100 * bar_h)
        for i in range(bar_h):
            row = i + 1
            is_filled = i >= (bar_h - filled)
            ch = '█' if is_filled else '░'
            try:
                stdscr.addstr(row, 1, ch * (w - 2),
                               curses.color_pair(1) if is_filled else curses.A_DIM)
            except curses.error:
                pass

        hint = 'j/k  m  q'
        stdscr.addstr(h - 2, max(0, (w - len(hint)) // 2), hint, curses.A_DIM)
        stdscr.refresh()

        key = stdscr.getch()
        if key in (ord('q'), ord('Q'), 27):
            break
        elif key in (ord('k'), curses.KEY_UP):
            vol = min(100, vol + 5)
            muted = False
            set_vol(vol)
        elif key in (ord('j'), curses.KEY_DOWN):
            vol = max(0, vol - 5)
            muted = False
            set_vol(vol)
        elif key == ord('m'):
            toggle_mute()
        vol, muted = get_vol()

curses.wrapper(main)
